<project xmlns="http://maven.apache.org/POM/4.0.0" 
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>com.mycompany</groupId>
    <artifactId>ProyectoFinalDam_1</artifactId>
    <version>1.0-SNAPSHOT</version>
    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <version>3.12.0</version>
                <configuration>
                    <!-- Keep html/reference/syntax/accessibility checks but skip 'missing'
                         (doclint:missing checks private fields in JDK 21 regardless of show level,
                          which conflicts with NetBeans GEN-BEGIN:variables auto-generated code) -->
                    <doclint>html,reference,syntax,accessibility</doclint>

                    <!-- Títulos y metadatos -->
                    <windowtitle>CRISS — Sistema de Gestión de Centro de Formación</windowtitle>
                    <doctitle><![CDATA[<strong style="font-size:1.4em;letter-spacing:-0.02em">CRISS</strong>
                        <span style="font-weight:400;color:#475569;font-size:0.75em;display:block;margin-top:4px">
                            Sistema de Gestión de Centro de Formación &nbsp;&middot;&nbsp;
                            Java 21 + Swing + MySQL &nbsp;&middot;&nbsp; DAM1 · 2026
                        </span>]]></doctitle>
                    <header><![CDATA[<span style="font-weight:800;color:#ffffff;font-size:15px;letter-spacing:-0.02em">CRISS</span>&nbsp;
                        <span style="color:#64748b;font-size:11px">Sistema de Gestión de Centro de Formación</span>]]></header>
                    <footer><![CDATA[<span style="color:#64748b;font-size:11px">&copy; 2026 isard &middot; DAM1 &middot; ProyectoFinalDam1</span>]]></footer>
                    <bottom><![CDATA[<div style="text-align:center;color:#94a3b8;font-size:11px;padding:6px 0">
                        Generado con Maven Javadoc Plugin 3.12 &middot; Java 21 &middot; 2026-05-31
                    </div>]]></bottom>

                    <!-- Página de resumen del proyecto -->
                    <overview>${project.basedir}/src/main/javadoc/overview.html</overview>

                    <!-- Tema visual personalizado (añadido encima del CSS por defecto) -->
                    <additionalJOptions>
                        <additionalJOption>--add-stylesheet</additionalJOption>
                        <additionalJOption>${project.basedir}/src/main/javadoc/stylesheet-custom.css</additionalJOption>
                    </additionalJOptions>

                    <!-- Mostrar miembros protegidos y públicos -->
                    <show>protected</show>

                    <!-- Incluir autor y versión en la salida -->
                    <author>true</author>
                    <version>true</version>
                    <use>true</use>

                    <!-- Directorio de salida dentro de Info/ (fuera de target/) -->
                    <outputDirectory>${project.basedir}/Info/Javadoc</outputDirectory>
                    <reportOutputDirectory>${project.basedir}/Info/Javadoc</reportOutputDirectory>

                    <!-- Eliminar páginas opcionales para reducir archivos sueltos -->
                    <nohelp>true</nohelp>
                    <notree>true</notree>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.2</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals><goal>shade</goal></goals>
                        <configuration>
                            <transformers>
                                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                                    <mainClass>Main.ProyectoFinalDam1</mainClass>
                                </transformer>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                        <exclude>module-info.class</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>com.akathist.maven.plugins.launch4j</groupId>
                <artifactId>launch4j-maven-plugin</artifactId>
                <version>2.4.0</version>
                <executions>
                    <execution>
                        <phase>verify</phase>
                        <goals><goal>launch4j</goal></goals>
                        <configuration>
                            <headerType>gui</headerType>
                            <jar>${project.build.directory}/${project.build.finalName}.jar</jar>
                            <outfile>${project.build.directory}/CentroFormacion.exe</outfile>
                            <jre>
                                <path></path>
                                <minVersion>21.0.0</minVersion>
                            </jre>
                            <versionInfo>
                                <fileVersion>1.0.0.0</fileVersion>
                                <txtFileVersion>1.0</txtFileVersion>
                                <fileDescription>Sistema de Gestion - Centro de Formacion</fileDescription>
                                <copyright>Rich</copyright>
                                <productVersion>1.0.0.0</productVersion>
                                <txtProductVersion>1.0</txtProductVersion>
                                <productName>Centro Formacion</productName>
                                <internalName>CentroFormacion</internalName>
                                <originalFilename>CentroFormacion.exe</originalFilename>
                            </versionInfo>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <dependencies>
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>9.7.0</version>
        </dependency>
        <dependency>
            <groupId>com.google.code.gson</groupId>
            <artifactId>gson</artifactId>
            <version>2.14.0</version>
        </dependency>
    </dependencies>
</project>